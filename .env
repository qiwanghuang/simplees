# 应用名称，只用于日志、启动信息等展示
APP_NAME=simplees

# 接口服务监听地址
# 127.0.0.1 表示只允许本机访问，适合本地开发
APP_HOST=127.0.0.1

# 接口服务端口
# 启动后访问地址会是 http://127.0.0.1:8000
APP_PORT=8000

# SQLite 数据库文件路径
# ./data/simplees.db 表示数据库文件放在项目根目录的 data 文件夹里
SQLITE_DB_PATH=./data/simplees.db

# Elasticsearch 服务地址
# 如果你本地用 Docker 启动 ES，通常就是 http://127.0.0.1:9200
ES_HOST=http://127.0.0.1:9200

# Elasticsearch 用户名
# 本地开发如果没有开启账号密码，可以留空
ES_USERNAME=

# Elasticsearch 密码
# 本地开发如果没有开启账号密码，可以留空
ES_PASSWORD=

# 商品搜索使用的 ES 索引名
# 后面商品、品牌、类目会合并成商品搜索文档写入这个索引
ES_PRODUCT_INDEX=product_search

# 请求 ES 的超时时间，单位：秒
# 超过这个时间 ES 还没响应，就认为请求失败
ES_REQUEST_TIMEOUT_SECONDS=5

# 搜索接口默认每页返回多少条
SEARCH_DEFAULT_PAGE_SIZE=10

# 搜索接口最多允许每页返回多少条
# 防止一次请求返回太多数据
SEARCH_MAX_PAGE_SIZE=50
