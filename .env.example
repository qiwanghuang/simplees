# 复制本文件即可得到本地开发配置：
# cp .env.example .env
#
# Docker Compose 会读取这个文件启动 MySQL、Elasticsearch、RabbitMQ、Canal、API 和 Consumer。
# Python 应用也会读取同一个 .env 连接这些本地服务。

# Docker 基础配置
COMPOSE_PROJECT_NAME=simplees
DOCKER_TIMEZONE=Asia/Shanghai
APP_IMAGE=simplees-app:local
PYTHON_IMAGE=docker.m.daocloud.io/library/python:3.11-slim

# Docker MySQL
MYSQL_IMAGE=mysql:8.0
MYSQL_PORT=3306
MYSQL_DATABASE=simplees
MYSQL_ROOT_PASSWORD=111111
MYSQL_APP_USER=simplees
MYSQL_APP_PASSWORD=simplees123
MYSQL_CHARSET=UTF-8

# Canal 连接 MySQL 使用的复制账号。
CANAL_MYSQL_USER=canal
CANAL_MYSQL_PASSWORD=123456

# Docker Elasticsearch
ES_IMAGE=docker.elastic.co/elasticsearch/elasticsearch:8.15.3
ES_PORT=9200
ES_JAVA_OPTS="-Xms512m -Xmx512m"

# Docker RabbitMQ
RABBITMQ_IMAGE=rabbitmq:3.13-management
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_VHOST=simplees
RABBITMQ_USERNAME=simplees
RABBITMQ_PASSWORD=simplees123
RABBITMQ_EXCHANGE=simplees.canal.exchange
RABBITMQ_QUEUE=simplees.canal.queue
RABBITMQ_ROUTING_KEY=simplees.canal.routing
RABBITMQ_EXCHANGE_TYPE=direct

# Docker Canal
CANAL_IMAGE=canal/canal-server:v1.1.7
CANAL_PORT=11111
CANAL_DESTINATION=canales
CANAL_FILTER=simplees\..*
CANAL_FILTER_BLACK_REGEX=mysql\..*,information_schema\..*,performance_schema\..*,sys\..*

# Application
APP_NAME=simplees
APP_HOST=127.0.0.1
APP_PORT=8000

# MySQL
DATABASE_URL=mysql+pymysql://simplees:simplees123@127.0.0.1:3306/simplees?charset=utf8mb4

# Database pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=280

# Elasticsearch
ES_HOST=http://127.0.0.1:9200
ES_USERNAME=
ES_PASSWORD=
ES_PRODUCT_INDEX=product_search
ES_REQUEST_TIMEOUT_SECONDS=5

# Canal TCP 调试配置。
# 当前主流程是 Canal -> RabbitMQ，Python 不直接消费 Canal TCP。
CANAL_HOST=127.0.0.1
CANAL_CLIENT_ID=1001
CANAL_USERNAME=
CANAL_PASSWORD=
CANAL_DATABASE=simplees
CANAL_BATCH_SIZE=100
CANAL_EMPTY_SLEEP_SECONDS=1

# RabbitMQ Consumer
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_RECONNECT_SECONDS=3

# Search pagination
SEARCH_DEFAULT_PAGE_SIZE=10
SEARCH_MAX_PAGE_SIZE=50
