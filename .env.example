# Application
APP_NAME=simplees
APP_HOST=127.0.0.1
APP_PORT=8000

# MySQL
DATABASE_URL=mysql+pymysql://simplees:change_me@127.0.0.1:3306/simplees?charset=utf8mb4

# Database pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=280

# Elasticsearch
ES_HOST=http://127.0.0.1:9200
ES_USERNAME=
ES_PASSWORD=
ES_PRODUCT_INDEX=product_search
ES_REQUEST_TIMEOUT_SECONDS=5

# Search pagination
SEARCH_DEFAULT_PAGE_SIZE=10
SEARCH_MAX_PAGE_SIZE=50
